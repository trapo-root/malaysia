(function () {

    // =============================================================
    //  CONFIGURATION — FREE GIFT (Wiper)
    // =============================================================
    //  Runtime:
    //    window.FREE_GIFT_WIPER_ENABLED = false;  // disable WIPER gift
    //    window.FREE_GIFT_WIPER_ENABLED = true;   // enable WIPER gift
    // =============================================================

    var FREE_GIFT_WIPER_DEFAULT = true;

    if (typeof window.FREE_GIFT_WIPER_ENABLED === 'undefined') {
        window.FREE_GIFT_WIPER_ENABLED = FREE_GIFT_WIPER_DEFAULT;
    }

    // =============================================================
    //  CONFIGURATION — GWP MIN SPEND RM100 (Shineguard 150ML)
    // =============================================================
    //  Free 1x 150ML Shineguard when cart subtotal >= RM100
    //  Variant ID : 40932973641805
    //
    //  Runtime:
    //    window.GWP_MIN_SPEND_ENABLED = false;  // disable
    //    window.GWP_MIN_SPEND_ENABLED = true;   // enable
    // =============================================================

    var GWP_MIN_SPEND_DEFAULT = true;

    if (typeof window.GWP_MIN_SPEND_ENABLED === 'undefined') {
        window.GWP_MIN_SPEND_ENABLED = GWP_MIN_SPEND_DEFAULT;
    }

    // =============================================================
    //  GIFT VARIANT IDS
    // =============================================================
    var GIFT_WIPER_VARIANT_ID = 42418196643917;
    var GWP_VARIANT_ID = 40932973641805;  // 150ML Shineguard
    var MIN_SPEND_CENTS = 10000;           // RM100

    // Helpers
    function isWiperGiftEnabled() { return !!window.FREE_GIFT_WIPER_ENABLED; }
    function isGWPMinSpendEnabled() { return !!window.GWP_MIN_SPEND_ENABLED; }

    // =============================================================
    //  FREE GIFT LOGIC — Wiper gift
    // =============================================================
    function calculateWiperGiftQty(items) {
        var requiredQty = 0;

        if (isWiperGiftEnabled()) {
            items.forEach(function (item) {
                var productType = (item.product_type || '').toUpperCase();
                var quantity = item.quantity || 0;

                if (productType === 'WIPER') {
                    requiredQty += quantity;
                }
            });
        }

        return requiredQty;
    }

    // =============================================================
    //  GWP MIN SPEND LOGIC — Min Spend RM100 → Free Shineguard
    // =============================================================
    function calculateGWPMinSpendUpdate(items) {
        if (!isGWPMinSpendEnabled()) {
            return { variantId: GWP_VARIANT_ID, requiredQty: 0 };
        }

        var EXCLUDED_VARIANT_IDS = {};
        EXCLUDED_VARIANT_IDS[GIFT_WIPER_VARIANT_ID] = true;
        EXCLUDED_VARIANT_IDS[GWP_VARIANT_ID] = true;

        var qualifyingSubtotal = 0;

        items.forEach(function (item) {
            if (!EXCLUDED_VARIANT_IDS[item.variant_id]) {
                qualifyingSubtotal += (item.final_line_price || item.line_price || 0);
            }
        });

        return {
            variantId: GWP_VARIANT_ID,
            requiredQty: qualifyingSubtotal >= MIN_SPEND_CENTS ? 1 : 0,
            qualifyingSubtotal: qualifyingSubtotal
        };
    }

    // =============================================================
    //  SINGLE CART UPDATE — merge all gift changes into one fetch
    // =============================================================
    function applyGiftUpdates(items, wiperQty, gwpResult) {
        var currentQty = {};
        items.forEach(function (item) {
            if (item.variant_id === GIFT_WIPER_VARIANT_ID || item.variant_id === GWP_VARIANT_ID) {
                currentQty[item.variant_id] = item.quantity;
            }
        });

        var allRequired = {};
        allRequired[GIFT_WIPER_VARIANT_ID] = wiperQty;
        allRequired[GWP_VARIANT_ID] = gwpResult.requiredQty;

        var updates = {};
        var needsUpdate = false;

        for (var variantId in allRequired) {
            var current = currentQty[variantId] || 0;
            var required = allRequired[variantId];
            if (current !== required) {
                updates[variantId] = required;
                needsUpdate = true;
            }
        }

        if (needsUpdate) {
            console.log('Cart Gift Logic: Updating cart', updates);

            fetch('/cart/update.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ updates: updates })
            })
                .then(function (r) { return r.json(); })
                .then(function (data) { console.log('Cart gifts updated successfully', data); })
                .catch(function (err) { console.error('Cart gift update error:', err); });
        }
    }

    // =============================================================
    //  MAIN EVENT LISTENER
    // =============================================================
    document.addEventListener('CART_UPDATED', function (event) {
        var cartObject = event.detail || {};

        // --- EXISTING LOGIC STARTS ---
        if (document.querySelector('.pickup-in-store-1')) {
            if (!$('.pickup-in-store-1').hasClass("addedNote")) {
                $(".pickup-in-store-1 .wow-cart-product-price-block").append(
                    "<p class='pickup-note'>Note : Our staff will contact you once your item is available to pick up</p>"
                );
            }
            $('.pickup-in-store-1').addClass('addedNote');
        }

        // Clear cart if cart only has free products
        if (cartObject.item_count > 0 && cartObject.items_subtotal_price === 0) {
            var addonProducts = ((window.wowcart || {}).cartItems || {}).items || [];
            if (!addonProducts.length && cartObject.items) {
                addonProducts = cartObject.items;
            }

            addonProducts = addonProducts.filter(function (item) {
                return item.product_type == 'Add-On' ||
                    item.product_type == 'Promotional' ||
                    item.product_type == 'Reward';
            });

            var currentCount = (window.wowcart || {}).item_count || cartObject.item_count;

            if ((addonProducts || {}).length == currentCount) {
                (window.wowcart || {}).clearCart && (window.wowcart || {}).clearCart();
            }
        }
        removeQuantitySelector();
        initOrGetLocsStorePickup();
        // --- EXISTING LOGIC ENDS ---

        // ---------------------------------------------------------
        //  GIFT LOGIC (Wiper Free Gift + GWP Min Spend RM100)
        // ---------------------------------------------------------
        try {
            var items = cartObject.items || [];

            // 1. Calculate wiper free-gift required quantity
            var wiperQty = calculateWiperGiftQty(items);

            if (!isWiperGiftEnabled()) {
                console.log('Wiper Gift Logic: DISABLED — skipping.');
            }

            // 2. Calculate GWP min-spend required quantity
            var gwpResult = calculateGWPMinSpendUpdate(items);

            if (!isGWPMinSpendEnabled()) {
                console.log('GWP Min Spend Logic: DISABLED — skipping.');
            }

            // 3. Merge and apply in a single fetch
            applyGiftUpdates(items, wiperQty, gwpResult);

        } catch (e) {
            console.error('Error in Cart Gift Logic:', e);
        }
    });

})();


</script>
